@page
@model KHBAddressPortal.Pages.AdminModel
@{ Layout = null; }
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Admin Dashboard · KHB</title><link rel="stylesheet" href="~/css/site.css"/><link rel="stylesheet" href="~/css/admin.css"/><link rel="stylesheet" href="~/css/admin-extra.css"/></head><body>
<div class="tricolor"></div><header class="gov-header header-row"><div class="brand"><div class="logo">KHB</div><div><h1>Karnataka Housing Board</h1><p>ಕರ್ನಾಟಕ ಗೃಹ ಮಂಡಳಿ</p><small>PROFILE UPDATE ADMINISTRATION PORTAL  · GOVERNMENT OF KARNATAKA</small></div></div><form method="post" asp-page-handler="Logout"><button class="logout">Logout</button></form></header><nav class="nav"><b>Dashboard</b><span>All Requests</span><span>Reports</span><span>Audit Log</span></nav>
<main class="form-shell"><div class="admin-heading"><div><h2>Admin Dashboard</h2><p>Welcome, Registrar <strong>@Model.StaffId</strong></p></div><span class="role-badge">ADMIN</span></div>@if(!string.IsNullOrWhiteSpace(Model.StatusMessage)){<div class="alert success">@Model.StatusMessage</div>}
<section class="summary-grid"><div class="summary-card"><strong>4</strong><span>Total Requests</span></div><div class="summary-card"><strong>4</strong><span>Pending</span></div><div class="summary-card"><strong>0</strong><span>Approved</span></div><div class="summary-card"><strong>0</strong><span>Rejected</span></div></section>
<section class="card"><div class="card-title title-row"><h2>Applicant Update Requests</h2><code>Unified Review Queue</code></div><div class="table-wrap"><table><thead><tr><th>Request ID</th><th>Application No.</th><th>Applicant</th><th>Type</th><th>Submitted</th><th>Status</th><th>Actions</th></tr></thead><tbody>
@foreach(var request in Model.Requests){<tr><td>@request.Id</td><td>@request.ApplicationNumber</td><td>@request.Applicant</td><td><span class="type-pill">@request.Type</span></td><td>@request.Submitted</td><td><span class="pending-status">Pending</span></td><td class="action-cell"><button type="button" class="mini view" onclick="document.getElementById('detail-@request.Id').classList.toggle('show')">View</button><form method="post" asp-page-handler="Approve"><input type="hidden" name="requestId" value="@request.Id"/><button class="mini approve">Approve</button></form><form method="post" asp-page-handler="Reject"><input type="hidden" name="requestId" value="@request.Id"/><button class="mini reject">Reject</button></form></td></tr><tr id="detail-@request.Id" class="detail-row"><td colspan="7"><div><b>Current:</b> @request.CurrentValue<br/><b>Requested:</b> @request.NewValue<br/><b>Document:</b> @request.Document</div></td></tr>}
</tbody></table></div></section></main><footer>© Karnataka Housing Board — Administration Portal Prototype</footer></body></html>
