@page
@model KHBAddressPortal.Pages.UpdateRequestModel
@{ Layout = null; var title = Model.Type == "Address" ? "Change Address" : Model.Type == "Name" ? "Correct Applicant Name" : $"Update {Model.Type}"; }
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>@title · KHB</title><link rel="stylesheet" href="~/css/site.css"/><link rel="stylesheet" href="~/css/dashboard.css"/></head><body>
<div class="tricolor"></div><header class="gov-header"><div class="brand"><div class="logo">KHB</div><div><h1>Karnataka Housing Board</h1><p>ಕರ್ನಾಟಕ ಗೃಹ ಮಂಡಳಿ</p><small>APPLICANT PROFILE UPDATE PORTAL · GOVERNMENT OF KARNATAKA</small></div></div></header><nav class="nav"><a asp-page="/ApplicantDashboard">Dashboard</a><b>@title</b></nav>
<main class="form-shell"><div class="breadcrumb"><a asp-page="/ApplicantDashboard">Dashboard</a> / @title</div><form method="post" enctype="multipart/form-data" class="card address-card">@Html.AntiForgeryToken()<input asp-for="Type" type="hidden"/><div class="card-title title-row"><h2>@title Request</h2><code>@Model.ApplicationNumber</code></div><div class="card-body"><div asp-validation-summary="ModelOnly" class="field-error"></div>
<h3>Current Registered Information</h3><label>Current @Model.Type</label><input value="@Model.CurrentValue" readonly/>
<h3>New Information</h3>
@if(Model.Type=="Address"){
 <div class="grid"><div><label asp-for="AddressLine">House No / Street</label><input asp-for="AddressLine" placeholder="Enter house number and street"/></div><div><label asp-for="Area"></label><input asp-for="Area" placeholder="Enter area/locality"/></div><div><label asp-for="City"></label><input asp-for="City" placeholder="Enter city"/></div><div><label asp-for="State"></label><input asp-for="State" placeholder="Enter state"/></div><div><label asp-for="PinCode">PIN Code</label><input asp-for="PinCode" maxlength="6" placeholder="Enter 6-digit PIN code"/></div></div>
}else{
 <label asp-for="NewValue">New @Model.Type</label><input asp-for="NewValue" type="@(Model.Type=="Email"?"email":Model.Type=="Phone"?"tel":"text")" placeholder="Enter new @Model.Type.ToLower()"/><span asp-validation-for="NewValue" class="field-error"></span>
}
<h3>Reason and Supporting Proof</h3><label asp-for="Reason">Reason for update</label><textarea asp-for="Reason" placeholder="Explain why this information needs to be updated"></textarea><span asp-validation-for="Reason" class="field-error"></span><label asp-for="Document">Supporting Document</label><div class="dropzone" id="dropzone">Choose File — click to attach</div><input asp-for="Document" class="hidden-file" accept=".pdf,.jpg,.jpeg,.png"/><span asp-validation-for="Document" class="field-error"></span><small class="file-hint">Accepted: PDF, JPG, PNG · Maximum size: 5 MB</small><label class="confirm"><input asp-for="Confirmed"/> I confirm that the information and document provided are correct.</label><span asp-validation-for="Confirmed" class="field-error"></span><div class="actions"><a asp-page="/ApplicantDashboard" class="btn outline">Cancel</a><button class="btn">Submit Request</button></div></div></form></main><footer>© Karnataka Housing Board — Profile Update Portal Prototype</footer><script src="~/js/site.js"></script></body></html>
